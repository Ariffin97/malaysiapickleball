<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tournament Calendar - Malaysia Pickleball Association</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  
  <!-- FullCalendar CSS -->
  <link href='/css/vendor/fullcalendar.min.css' rel='stylesheet' />
  
  <style>
    /* Custom FullCalendar Styling */
    #calendar {
      max-width: 1400px;
      margin: 0 auto;
      background: white;
      padding: 20px;
      border-radius: 12px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }
    
    /* Style calendar header */
    .fc-toolbar {
      margin-bottom: 20px !important;
    }
    
    .fc-toolbar-title {
      font-size: 1.75rem !important;
      font-weight: 700 !important;
      color: #1f2937 !important;
    }
    
    .fc-button {
      background: #667eea !important;
      border: none !important;
      font-weight: 600 !important;
      padding: 8px 16px !important;
      transition: all 0.3s !important;
    }
    
    .fc-button:hover {
      background: #5a67d8 !important;
      transform: translateY(-1px);
    }
    
    .fc-button-active {
      background: #4c51bf !important;
    }
    
    /* Style day headers */
    .fc-col-header-cell {
      background: #f3f4f6 !important;
      padding: 12px 0 !important;
      font-weight: 700 !important;
      color: #374151 !important;
    }
    
    /* Weekend styling */
    .fc-day-sat, .fc-day-sun {
      background: #f0f4ff !important;
    }
    
    .fc-col-header-cell.fc-day-sat,
    .fc-col-header-cell.fc-day-sun {
      background: #e0e7ff !important;
      color: #4c1d95 !important;
    }
    
    /* Event styling by type */
    .fc-event {
      border: none !important;
      padding: 2px 4px !important;
      font-size: 0.875rem !important;
      font-weight: 600 !important;
      cursor: pointer !important;
    }
    
    .tournament-local {
      background: #10b981 !important;
      color: white !important;
    }
    
    .tournament-state {
      background: #ef4444 !important;
      color: white !important;
    }
    
    .tournament-national {
      background: #3b82f6 !important;
      color: white !important;
    }
    
    .tournament-sarawak {
      background: #8b5cf6 !important;
      color: white !important;
    }
    
    .tournament-wmalaysia {
      background: #f97316 !important;
      color: white !important;
    }
    
    /* Month boundaries */
    .fc-daygrid-day-number {
      font-weight: 600 !important;
      color: #374151 !important;
    }
    
    /* First day of month styling */
    .fc-day[data-date$="-01"] .fc-daygrid-day-number {
      background: #fee2e2;
      color: #dc2626 !important;
      padding: 2px 6px;
      border-radius: 4px;
      font-weight: 700 !important;
    }
    
    /* Hover effects */
    .fc-daygrid-day:hover {
      background: #f9fafb !important;
    }
    
    /* Today highlight */
    .fc-day-today {
      background: #fef3c7 !important;
    }
    
    /* Modal styling */
    .tournament-modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.5);
      z-index: 1000;
      align-items: center;
      justify-content: center;
    }
    
    .tournament-modal.show {
      display: flex;
    }
    
    .modal-content {
      background: white;
      padding: 2rem;
      border-radius: 12px;
      max-width: 500px;
      width: 90%;
      max-height: 80vh;
      overflow-y: auto;
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }
    
    /* Legend */
    .legend {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
      margin-bottom: 2rem;
    }
    
    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: #f9fafb;
      border-radius: 9999px;
      font-size: 0.875rem;
      font-weight: 600;
    }
    
    .legend-color {
      width: 16px;
      height: 16px;
      border-radius: 4px;
    }
    
    @media (max-width: 768px) {
      #calendar {
        padding: 10px;
      }
      
      .fc-toolbar {
        flex-direction: column;
        gap: 10px;
      }
      
      .fc-toolbar-chunk {
        display: flex;
        justify-content: center;
      }
      
      .fc-event {
        font-size: 0.75rem !important;
        padding: 1px 2px !important;
      }
    }
  </style>
</head>
<body class="bg-gray-50">
  <%- include('../partials/header') %>
  
  <main class="pt-24 p-4 pb-20">
    <div class="container mx-auto max-w-7xl">
      <!-- Page Header -->
      <div class="text-center mb-8">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-4">
          <i class="fas fa-calendar-alt mr-3 text-indigo-600"></i>
          2025 Tournament Calendar
        </h1>
        <p class="text-lg text-gray-600">View all tournaments in an interactive calendar</p>
      </div>
      
      <!-- Legend -->
      <div class="legend">
        <div class="legend-item">
          <div class="legend-color tournament-local"></div>
          <span>Local</span>
        </div>
        <div class="legend-item">
          <div class="legend-color tournament-state"></div>
          <span>State</span>
        </div>
        <div class="legend-item">
          <div class="legend-color tournament-national"></div>
          <span>National</span>
        </div>
        <div class="legend-item">
          <div class="legend-color tournament-sarawak"></div>
          <span>Sarawak</span>
        </div>
        <div class="legend-item">
          <div class="legend-color tournament-wmalaysia"></div>
          <span>W. Malaysia</span>
        </div>
      </div>
      
      <!-- Calendar Container -->
      <div id="calendar"></div>
      
      <!-- Action Buttons -->
      <div class="flex justify-center gap-4 mt-8">
        <a href="/tournament" class="bg-gray-600 hover:bg-gray-700 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-300">
          <i class="fas fa-arrow-left mr-2"></i>Back to List
        </a>
        <a href="/tournament/download-pdf" class="bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-300">
          <i class="fas fa-download mr-2"></i>Download PDF
        </a>
        <a href="/tournament/print-pdf" target="_blank" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-300">
          <i class="fas fa-print mr-2"></i>Print
        </a>
      </div>
    </div>
  </main>
  
  <!-- Tournament Details Modal -->
  <div id="tournamentModal" class="tournament-modal">
    <div class="modal-content">
      <div class="flex justify-between items-start mb-4">
        <h2 id="modalTitle" class="text-2xl font-bold text-gray-800"></h2>
        <button onclick="closeModal()" class="text-gray-500 hover:text-gray-700">
          <i class="fas fa-times text-xl"></i>
        </button>
      </div>
      <div id="modalBody" class="space-y-3">
        <!-- Modal content will be populated by JavaScript -->
      </div>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
  
  <!-- FullCalendar JS -->
  <script src='/js/vendor/fullcalendar.min.js'></script>
  
  <script>
    // Tournament data from server
    const tournaments = <%- JSON.stringify(tournaments || []) %>;
    
    // Convert tournaments to FullCalendar events
    const events = tournaments.map(tournament => {
      const event = {
        title: tournament.name,
        start: tournament.startDate,
        end: tournament.endDate ? new Date(new Date(tournament.endDate).getTime() + 86400000).toISOString().split('T')[0] : tournament.startDate,
        className: `tournament-${tournament.type || 'local'}`,
        extendedProps: {
          venue: tournament.venue,
          city: tournament.city,
          organizer: tournament.organizer,
          personInCharge: tournament.personInCharge,
          phoneNumber: tournament.phoneNumber,
          type: tournament.type,
          image: tournament.image
        }
      };
      
      return event;
    });
    
    // Initialize calendar
    document.addEventListener('DOMContentLoaded', function() {
      const calendarEl = document.getElementById('calendar');
      
      const calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        initialDate: '2025-01-01',
        headerToolbar: {
          left: 'prev,next today',
          center: 'title',
          right: 'dayGridMonth,timeGridWeek,listMonth'
        },
        height: 'auto',
        events: events,
        eventClick: function(info) {
          showTournamentDetails(info.event);
        },
        dayMaxEvents: 3,
        moreLinkText: function(num) {
          return '+' + num + ' more';
        },
        weekends: true,
        eventDisplay: 'block'
      });
      
      calendar.render();
    });
    
    // Show tournament details in modal
    function showTournamentDetails(event) {
      const modal = document.getElementById('tournamentModal');
      const modalTitle = document.getElementById('modalTitle');
      const modalBody = document.getElementById('modalBody');
      
      modalTitle.textContent = event.title;
      
      const typeColors = {
        local: 'bg-green-100 text-green-800',
        state: 'bg-red-100 text-red-800',
        national: 'bg-blue-100 text-blue-800',
        sarawak: 'bg-purple-100 text-purple-800',
        wmalaysia: 'bg-orange-100 text-orange-800'
      };
      
      const props = event.extendedProps;
      
      let html = `
        <div class="space-y-3">
          <div>
            <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold ${typeColors[props.type] || typeColors.local}">
              ${props.type ? props.type.toUpperCase() : 'LOCAL'}
            </span>
          </div>
      `;
      
      // Add dates
      const startDate = new Date(event.start);
      const endDate = event.end ? new Date(event.end) : null;
      
      html += `
        <div class="flex items-center text-gray-700">
          <i class="fas fa-calendar-alt mr-3 text-indigo-500"></i>
          <span>
            ${startDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            ${endDate && endDate.getTime() !== startDate.getTime() ? 
              ` - ${endDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}` : 
              ''}
          </span>
        </div>
      `;
      
      // Add venue
      if (props.venue) {
        html += `
          <div class="flex items-start text-gray-700">
            <i class="fas fa-map-marker-alt mr-3 text-red-500 mt-1"></i>
            <span>${props.venue}${props.city ? `, ${props.city}` : ''}</span>
          </div>
        `;
      }
      
      // Add organizer
      if (props.organizer) {
        html += `
          <div class="flex items-start text-gray-700">
            <i class="fas fa-building mr-3 text-green-500 mt-1"></i>
            <span>Organized by: ${props.organizer}</span>
          </div>
        `;
      }
      
      // Add contact person
      if (props.personInCharge) {
        html += `
          <div class="flex items-start text-gray-700">
            <i class="fas fa-user mr-3 text-blue-500 mt-1"></i>
            <span>Contact: ${props.personInCharge}</span>
          </div>
        `;
      }
      
      // Add phone
      if (props.phoneNumber && props.phoneNumber !== 'Not Available') {
        html += `
          <div class="flex items-center text-gray-700">
            <i class="fas fa-phone mr-3 text-purple-500"></i>
            <span>${props.phoneNumber}</span>
          </div>
        `;
      }
      
      // Add image if exists
      if (props.image) {
        html += `
          <div class="mt-4">
            <img src="${props.image}" alt="${event.title}" class="w-full rounded-lg">
          </div>
        `;
      }
      
      html += '</div>';
      
      modalBody.innerHTML = html;
      modal.classList.add('show');
    }
    
    // Close modal
    function closeModal() {
      const modal = document.getElementById('tournamentModal');
      modal.classList.remove('show');
    }
    
    // Close modal on outside click
    document.getElementById('tournamentModal').addEventListener('click', function(e) {
      if (e.target === this) {
        closeModal();
      }
    });
  </script>
</body>
</html>